# Optional: when set, nova_roleplay_brain.py loads personas from
# ${UNCENSORED_VAULT_PATH}/candy-ai-clone/personas.json instead of the
# built-in dict. Used to keep NSFW prompt content in a private vault repo
# (see roseonlineownz-lab/uncensored-vault). When unset or the file is
# missing, behavior is identical to before — built-in personas are used.
UNCENSORED_VAULT_PATH=
